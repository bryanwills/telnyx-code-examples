# Telnyx API credentials — get yours at https://portal.telnyx.com

TELNYX_API_KEY=your_telnyx_api_key_here

# Telnyx Ed25519 public key for webhook signature verification — find it in the
# portal under Account Settings > Keys & Credentials > Public Key.
# Required: the SDK refuses to verify (and rejects) webhooks without it.
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here

# Port the HttpServer listens on (defaults to 8080 if unset).
PORT=8080
