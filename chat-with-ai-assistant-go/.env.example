# Telnyx API credentials — get yours at https://portal.telnyx.com

TELNYX_API_KEY=KEY_your_telnyx_api_key_here

# The AI assistant to chat with. Create one in the Telnyx Portal under
# AI Assistants, then copy its ID (looks like assistant-xxxxxxxx).
TELNYX_ASSISTANT_ID=assistant_your_assistant_id_here

# Port the Gin server listens on. Defaults to 8080 when unset.
PORT=8080
