# Telnyx API credentials — get yours at https://portal.telnyx.com/app/api-keys

# Required: Telnyx API v2 key (starts with "KEY...").
TELNYX_API_KEY=your_telnyx_api_key_here

# Optional: base64 Ed25519 public key for verifying inbound webhook signatures.
# Only needed if you extend this example to receive Telnyx webhooks.
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here

# Optional: port the local HTTP server listens on (defaults to 8080).
PORT=8080
