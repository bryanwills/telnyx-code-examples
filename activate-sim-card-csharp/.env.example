# Telnyx API credentials — get yours at https://portal.telnyx.com/app/api-keys
TELNYX_API_KEY=your_telnyx_api_key_here

# Account public key used to verify inbound webhook (Ed25519) signatures.
# Find it in the Telnyx Portal under Account > Keys & Credentials > Public Key.
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here

# Optional: port for the local server (defaults to 5000 / Kestrel default).
# ASPNETCORE_URLS=http://localhost:5000
