# Telnyx API credentials — get yours at https://portal.telnyx.com

# Telnyx API v2 key (Portal > API Keys). Required.
TELNYX_API_KEY=your_telnyx_api_key_here

# Telnyx number to send from, in E.164 format (Portal > Numbers > My Numbers). Required.
TELNYX_PHONE_NUMBER=+15551234567

# Account base64 public key (Portal > Account > Public Key).
# Required only for the /webhooks/sms endpoint (Ed25519 signature verification).
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here
