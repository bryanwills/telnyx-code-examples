# Telnyx API credentials — get yours at https://portal.telnyx.com/api-keys
# Copy this file to .env and fill in real values. Never commit .env.

# Required: Telnyx API v2 key (Portal → API Keys)
TELNYX_API_KEY=your_telnyx_api_key_here

# Required: Telnyx number you own, in E.164 format (the caller ID)
TELNYX_PHONE_NUMBER=+15551234567

# Required: Call Control Application (connection) ID
# (Portal → Call Control → Applications)
TELNYX_CONNECTION_ID=your_connection_id_here

# Optional: HTTPS URL Telnyx posts call events to
# (e.g. https://your-ngrok-id.ngrok.io/webhooks/voice)
TELNYX_WEBHOOK_URL=https://your-public-url/webhooks/voice

# Required only for webhook signature verification: base64 Ed25519 public key
# (Portal → Account → Keys & Credentials → Public Key)
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here

# Optional: HTTP port (defaults to 8080)
PORT=8080
