# Telnyx API credentials — get yours at https://portal.telnyx.com

TELNYX_API_KEY=your_telnyx_api_key_here

# The AI Assistant to chat with (find it under AI > Assistants in the Telnyx Portal)
TELNYX_ASSISTANT_ID=your_assistant_id_here

# Optional: port the HttpServer listens on (defaults to 8080)
PORT=8080
