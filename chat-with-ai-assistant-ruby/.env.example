# Telnyx API credentials — get yours at https://portal.telnyx.com

# Telnyx API v2 key (Portal > API Keys). Required.
TELNYX_API_KEY=your_telnyx_api_key_here

# ID of the AI Assistant to chat with (Portal > AI > Assistants). Required.
AI_ASSISTANT_ID=your_assistant_id_here

# Base64 Ed25519 public key for verifying inbound webhooks
# (Portal > Account > Keys & Credentials > Public Key). Required only if you
# use the POST /webhooks/ai endpoint.
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here

# Port the server listens on (optional; defaults to 3000).
PORT=3000
