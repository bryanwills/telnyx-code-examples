# Telnyx API credentials — get yours at https://portal.telnyx.com
TELNYX_API_KEY=KEY_your_telnyx_api_key_here

# Telnyx public key for webhook signature verification — find it in the
# Telnyx portal under your application / Account Settings (Public Key)
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here

# AI model for conversation (Telnyx Inference)
AI_MODEL=meta-llama/Llama-3.3-70B-Instruct

# System prompt — customize your agent's personality
SYSTEM_PROMPT=You are a helpful voice AI agent for a business. Keep responses concise.

# Optional: phone number for human transfer
TRANSFER_NUMBER=+1XXXXXXXXXX

# Server settings
PORT=5000
