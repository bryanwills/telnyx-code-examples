# Telnyx API credentials — get yours at https://portal.telnyx.com

# Telnyx API v2 key (Portal > Account > Keys & Credentials > API Keys).
TELNYX_API_KEY=your_telnyx_api_key_here

# Call Control Application ID that owns the outbound call leg
# (Portal > Call Control > Applications).
TELNYX_CONNECTION_ID=your_connection_id_here

# Telnyx phone number to place the call from, in E.164 format.
TELNYX_PHONE_NUMBER=+15551234567

# Public HTTPS URL where Telnyx should deliver call lifecycle webhooks
# (optional; e.g. an ngrok URL ending in /webhooks/voice).
TELNYX_VOICE_WEBHOOK_URL=https://your-domain.example.com/webhooks/voice

# Base64 Ed25519 public key for verifying inbound webhook signatures
# (Portal > Account > Keys & Credentials > Public Key).
# Only required if you receive call webhooks on /webhooks/voice.
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here

# Port the Sinatra server listens on (optional; defaults to 4567).
PORT=4567
