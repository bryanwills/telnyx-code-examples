# Telnyx API credentials — get yours at https://portal.telnyx.com/api-keys

# Required: Telnyx API v2 key. Used to authenticate the Telnyx SDK client.
TELNYX_API_KEY=your_telnyx_api_key_here

# Required: base64 Ed25519 public key from the Telnyx Portal (Account → Public Key).
# Used by the SDK to verify the Telnyx-Signature-Ed25519 header on inbound webhooks.
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here
