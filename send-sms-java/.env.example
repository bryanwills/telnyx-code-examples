# Telnyx API credentials — get yours at https://portal.telnyx.com

# Telnyx API v2 key (https://portal.telnyx.com/api-keys)
TELNYX_API_KEY=your_telnyx_api_key_here

# Telnyx number to send from, in E.164 format (https://portal.telnyx.com/numbers/my-numbers)
TELNYX_PHONE_NUMBER=+15551234567

# Optional: HTTP port the local server binds to (defaults to 5000)
PORT=5000
