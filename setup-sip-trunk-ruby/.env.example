# Telnyx API credentials — get yours at https://portal.telnyx.com

# Telnyx API v2 key (Portal > Account > Keys & Credentials). Required.
TELNYX_API_KEY=your_telnyx_api_key_here

# Base64 Ed25519 public key for verifying inbound webhook signatures
# (Portal > Account > Keys & Credentials > Public Key). Required only if you
# use the /webhooks/sip endpoint.
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here

# Port for the Sinatra server (defaults to 4567 if unset).
PORT=4567
