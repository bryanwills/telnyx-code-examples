# Edge Compute Webhook Proxy
# Verify inbound Telnyx webhook signatures (Portal > Keys & Credentials > Public Key)
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here
# Backend to forward enriched webhooks to (https only)
FORWARD_URL=https://your-backend.example.com/webhooks
# Optional HMAC secret for the X-Edge-Signature on forwarded requests
FORWARD_SECRET=your_forward_secret_here
# Local testing
TELNYX_API_KEY=your_telnyx_api_key_here
