# Telnyx API credentials — get yours at https://portal.telnyx.com

# Required: Telnyx API v2 key (Portal > API Keys).
TELNYX_API_KEY=your_telnyx_api_key_here

# Required for webhook verification: your account's base64 Ed25519 public key
# (Portal > Account > Public Key). Used by /webhooks/telnyx to verify signatures.
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here

# Optional: override the Telnyx API base URL (defaults to https://api.telnyx.com/v2).
# TELNYX_API_BASE_URL=https://api.telnyx.com/v2
