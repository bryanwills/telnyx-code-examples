# Telnyx API credentials — get yours at https://portal.telnyx.com/api-keys

# Required: Telnyx API v2 key. Used to authenticate every API call.
TELNYX_API_KEY=your_telnyx_api_key_here

# Optional: base64 Ed25519 public key from Mission Control.
# Required only if you receive webhooks at POST /webhooks/telnyx so the SDK can
# verify the Telnyx-Signature-Ed25519 header.
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here
