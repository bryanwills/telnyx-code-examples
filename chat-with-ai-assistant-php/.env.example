# Telnyx API credentials — get yours at https://portal.telnyx.com
# Copy this file to .env and fill in real values. Never commit .env.

# Telnyx API v2 key (https://portal.telnyx.com/api-keys)
TELNYX_API_KEY=your_telnyx_api_key_here

# ID of the AI Assistant to chat with (https://portal.telnyx.com/ai/assistants)
TELNYX_ASSISTANT_ID=your_assistant_id_here

# Base64 Ed25519 public key used to verify inbound webhook signatures
# (https://portal.telnyx.com — Account > Keys & Credentials > Public Key)
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here

# Port the PHP built-in server listens on (used in the Setup commands below)
PORT=8080
