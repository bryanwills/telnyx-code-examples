# Telnyx API credentials — get yours at https://portal.telnyx.com

# Telnyx API v2 key. Used to initialize the SDK client.
TELNYX_API_KEY=KEY_your_telnyx_api_key_here

# Telnyx Ed25519 PUBLIC key (base64), used to verify inbound webhook signatures.
# Portal > Account Settings > Keys & Credentials > Public Key.
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here

# Port the Sinatra server listens on (defaults to 5000 if unset).
PORT=5000
