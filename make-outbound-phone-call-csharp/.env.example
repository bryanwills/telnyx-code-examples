# Telnyx API credentials — get yours at https://portal.telnyx.com

# Telnyx API v2 key (Portal > API Keys)
TELNYX_API_KEY=your_telnyx_api_key_here

# Telnyx number you dial FROM, in E.164 format (Portal > Numbers > My Numbers)
TELNYX_PHONE_NUMBER=+15551234567

# Call Control Application ID — links the call to your Call Control app (required)
TELNYX_CONNECTION_ID=your_connection_id_here

# Base64 public key for verifying inbound webhook signatures (Portal > Account > Public Key)
TELNYX_PUBLIC_KEY=your_base64_public_key_here
