TELNYX_API_KEY=your_telnyx_api_key
AI_MODEL=moonshotai/Kimi-K2.6
TTS_MODEL=telnyx/tts
BUCKET_NAME=audiobooks
DEFAULT_VOICE=nova
# Telnyx Cloud Storage region. Selects the S3 endpoint host
# (e.g. us-central-1 -> us-central-1.telnyxcloudstorage.com).
# Options: us-central-1, us-east-1, us-west-1, eu-central-1
TELNYX_STORAGE_REGION=us-central-1
HOST=127.0.0.1
