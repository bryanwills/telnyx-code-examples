# Telnyx API credentials — get yours at https://portal.telnyx.com

# API v2 key (https://portal.telnyx.com/api-keys)
TELNYX_API_KEY=your_telnyx_api_key_here

# Telnyx number you dial from, in E.164 (https://portal.telnyx.com/numbers/my-numbers)
TELNYX_PHONE_NUMBER=+15551234567

# Call Control Application (connection) ID (https://portal.telnyx.com/call-control/applications)
TELNYX_CONNECTION_ID=your_connection_id_here

# Base64 Ed25519 public key for webhook signature verification
# (Mission Control Portal → Account Settings → Public Key)
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here
