# Telnyx credentials — get yours at https://portal.telnyx.com
# Copy this file to .env and fill in real values. Never commit .env.

# Telnyx API v2 key (Portal > API Keys). Used to configure the Telnyx SDK.
TELNYX_API_KEY=your_telnyx_api_key_here

# Base64 account public key (Portal > Account > Public Key). Required to verify
# the Ed25519 signature on every inbound webhook.
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here

# Optional: HTTP port the server listens on. ASP.NET reads ASPNETCORE_URLS or
# defaults to http://localhost:5000.
# ASPNETCORE_URLS=http://localhost:5000
