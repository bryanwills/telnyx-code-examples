# Telnyx API credentials — get yours at https://portal.telnyx.com

TELNYX_API_KEY=KEY_your_telnyx_api_key_here

# Telnyx webhook public key — used to verify inbound webhook signatures.
# Find it in the Telnyx portal under your application's webhook settings.
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here

PORT=5000
