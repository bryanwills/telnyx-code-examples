source "https://rubygems.org"

# Telnyx requires Ruby 3.2+. System Ruby on macOS (2.6) cannot install/run this;
# this example is validated statically only — CI on Ruby 3.2+ must confirm the build.
ruby ">= 3.2"

# Telnyx Ruby SDK — pinned to the verified 5.x line (instance client API).
gem "telnyx", "~> 5.131"

# Lightweight web framework for the webhook receiver.
gem "sinatra", "~> 4.1"

# Rack server to run the Sinatra app (`ruby app.rb`).
gem "puma", "~> 6.4"

# Loads .env into ENV for local development.
gem "dotenv", "~> 3.1"

# Native Ed25519 verification of Telnyx webhook signatures.
gem "ed25519", "~> 1.3"

# Transitive require of telnyx 5.x: lib/telnyx.rb does `require "standardwebhooks"`
# at load time, but the gem does not declare it as a runtime dependency, so
# `require "telnyx"` raises LoadError without it. Pinned explicitly.
gem "standardwebhooks", "~> 1.1"
