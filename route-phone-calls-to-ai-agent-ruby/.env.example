# Telnyx credentials — get yours at https://portal.telnyx.com
# Copy this file to .env and fill in real values. Never commit .env.

# Telnyx API v2 key (Portal > Account > Keys & Credentials > API Keys).
TELNYX_API_KEY=your_telnyx_api_key_here

# Base64-encoded Ed25519 public key used to verify inbound webhook signatures
# (Portal > Account > Keys & Credentials > Public Key).
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here

# The Telnyx AI assistant to route answered calls into
# (Portal > AI Assistants — the assistant's ID).
TELNYX_ASSISTANT_ID=assistant_your_assistant_id_here

# Optional: port for the local Sinatra server (defaults to 4567).
PORT=4567
